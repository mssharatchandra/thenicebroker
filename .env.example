# Postgres connection string (Neon, Supabase, Vercel Postgres, or local)
# Get one in 30 seconds at https://console.neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Public base URL of the deployed app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Shared secret Bolna sends to /api/bolna/webhook.
# Accepted headers: x-bolna-webhook-secret, x-webhook-secret, or Authorization: Bearer <secret>
BOLNA_WEBHOOK_SECRET="change-me-to-a-long-random-string"

# Optional until outbound/proactive calls are added
BOLNA_AGENT_ID=""
BOLNA_API_KEY=""
