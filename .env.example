# Postgres connection string (Neon, Supabase, Vercel Postgres, or local)
# Get one in 30 seconds at https://console.neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Public base URL of the deployed app (used to construct webhook URLs in docs/UI)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Shared secret Bolna sends in the X-Webhook-Signature header.
# Configure the same value when wiring the webhook on platform.bolna.ai.
BOLNA_WEBHOOK_SECRET="change-me-to-a-long-random-string"

# Optional: Bolna agent ID, useful if the dashboard ever needs to call back into Bolna's API
BOLNA_AGENT_ID=""
BOLNA_API_KEY=""
