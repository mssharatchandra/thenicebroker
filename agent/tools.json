[
  {
    "name": "upsert_lead",
    "description": "Create or update the renter profile extracted during a call. Call this whenever you learn a meaningful new requirement. Send only known fields; omit unknown fields.",
    "method": "POST",
    "url": "{{APP_URL}}/api/agent/upsert-lead",
    "headers": {
      "Content-Type": "application/json"
    },
    "body_schema": {
      "type": "object",
      "properties": {
        "call_id": { "type": "string", "description": "Use {call_sid} if available." },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "preferred_areas": { "type": "string", "description": "Comma-separated areas, e.g. HSR Layout,Whitefield." },
        "bhk": { "type": "string", "description": "Comma-separated BHK numbers, e.g. 2 or 2,3." },
        "budget_min_inr": { "type": "number" },
        "budget_max_inr": { "type": "number" },
        "move_in_by": { "type": "string", "description": "YYYY-MM-DD." },
        "occupants": { "type": "string", "enum": ["family", "bachelor", "couple", "flatmates"] },
        "veg_only": { "type": "boolean" },
        "pet_friendly": { "type": "boolean" },
        "parking_needed": { "type": "string", "enum": ["bike", "car", "either", "none"] },
        "furnishing_preference": { "type": "string", "description": "Comma-separated: unfurnished, semi, fully." },
        "work_from_home": { "type": "boolean" },
        "preferred_language": { "type": "string", "enum": ["en", "hi", "kn"] },
        "qual_score": { "type": "number" },
        "intent": { "type": "string", "enum": ["just-browsing", "actively-looking", "urgent"] },
        "notes": { "type": "string" }
      }
    }
  },
  {
    "name": "search_inventory",
    "description": "Search the Bangalore rental inventory using caller requirements and return scored matches with honest tradeoffs. Use after area/commute, BHK, budget ceiling, and occupant type are known.",
    "method": "POST",
    "url": "{{APP_URL}}/api/agent/search",
    "headers": {
      "Content-Type": "application/json"
    },
    "body_schema": {
      "type": "object",
      "properties": {
        "call_id": { "type": "string", "description": "Use {call_sid} if available." },
        "areas": {
          "type": "string",
          "description": "Comma-separated: HSR Layout, Whitefield, Indiranagar, Koramangala, BTM Layout, JP Nagar, Marathahalli, Electronic City, KR Puram, Old Madras Road, Bellandur, Sarjapur Road."
        },
        "bhk": { "type": "string", "description": "Comma-separated BHK numbers, e.g. 2 or 2,3." },
        "budget_min_inr": { "type": "number" },
        "budget_max_inr": { "type": "number" },
        "furnishing": { "type": "string", "description": "Comma-separated: unfurnished, semi, fully." },
        "parking_needed": { "type": "string", "enum": ["bike", "car", "either", "none"] },
        "pet_friendly": { "type": "boolean" },
        "veg_only": { "type": "boolean" },
        "occupants": { "type": "string", "enum": ["family", "bachelor", "couple", "flatmates"] },
        "move_in_by": { "type": "string", "description": "YYYY-MM-DD." },
        "min_carpet_sqft": { "type": "number" },
        "amenities": {
          "type": "string",
          "description": "Comma-separated: gym, pool, powerBackup, security, clubhouse, playArea, joggingTrack, indoorGames."
        },
        "limit": { "type": "number", "default": 3 }
      }
    }
  },
  {
    "name": "compare_listings",
    "description": "Compare 2-5 rental listings across cost, deposit, area, furnishing, parking, age, amenities, commute, lift, and availability. Use before making a recommendation.",
    "method": "POST",
    "url": "{{APP_URL}}/api/agent/compare",
    "headers": {
      "Content-Type": "application/json"
    },
    "body_schema": {
      "type": "object",
      "required": ["listing_ids"],
      "properties": {
        "call_id": { "type": "string", "description": "Use {call_sid} if available." },
        "listing_ids": { "type": "string", "description": "Comma-separated listing IDs from search_inventory, e.g. tnb-hsr-001,tnb-wfd-004." }
      }
    }
  },
  {
    "name": "book_visit",
    "description": "Book a visit for a specific listing and slot once the caller confirms the listing and a concrete date/time.",
    "method": "POST",
    "url": "{{APP_URL}}/api/agent/book-visit",
    "headers": {
      "Content-Type": "application/json"
    },
    "body_schema": {
      "type": "object",
      "required": ["listing_id", "slot_iso"],
      "properties": {
        "call_id": { "type": "string", "description": "Use {call_sid} if available." },
        "lead_id": { "type": "string", "description": "Optional; can be omitted if call_id is available and upsert_lead was called." },
        "listing_id": { "type": "string" },
        "slot_iso": { "type": "string", "description": "ISO datetime with timezone, e.g. 2026-04-27T17:30:00+05:30. You may also use earliest if the caller says any available slot." },
        "channel": { "type": "string", "enum": ["in-person", "video"], "default": "in-person" },
        "notes": { "type": "string" }
      }
    }
  },
  {
    "name": "send_summary",
    "description": "Send or log a written comparison summary for the renter after shortlisting or booking. Use near the end of the call.",
    "method": "POST",
    "url": "{{APP_URL}}/api/agent/send-summary",
    "headers": {
      "Content-Type": "application/json"
    },
    "body_schema": {
      "type": "object",
      "required": ["listing_ids"],
      "properties": {
        "call_id": { "type": "string", "description": "Use {call_sid} if available." },
        "lead_id": { "type": "string", "description": "Optional; can be omitted if call_id is available and upsert_lead was called." },
        "listing_ids": { "type": "string", "description": "Comma-separated listing IDs from search_inventory." },
        "channel": { "type": "string", "enum": ["sms", "whatsapp", "email"], "default": "sms" }
      }
    }
  }
]
