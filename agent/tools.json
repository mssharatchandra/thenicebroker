[
  {
    "name": "upsert_lead",
    "description": "Create or update the renter profile extracted during a call. Call this whenever the agent learns a meaningful new requirement.",
    "method": "POST",
    "url": "{{APP_URL}}/api/agent/upsert-lead",
    "headers": {
      "Content-Type": "application/json"
    },
    "body_schema": {
      "type": "object",
      "required": ["lead"],
      "properties": {
        "call_id": {
          "type": "string",
          "description": "Bolna call id if available."
        },
        "lead": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "preferred_areas": {
              "type": "array",
              "items": { "type": "string" }
            },
            "bhk": {
              "type": "array",
              "items": { "type": "number" }
            },
            "budget_min_inr": { "type": "number" },
            "budget_max_inr": { "type": "number" },
            "move_in_by": { "type": "string", "description": "YYYY-MM-DD" },
            "occupants": {
              "type": "string",
              "enum": ["family", "bachelor", "couple", "flatmates"]
            },
            "veg_only": { "type": "boolean" },
            "pet_friendly": { "type": "boolean" },
            "parking_needed": {
              "type": "string",
              "enum": ["bike", "car", "either", "none"]
            },
            "furnishing_preference": {
              "type": "array",
              "items": { "type": "string" }
            },
            "work_from_home": { "type": "boolean" },
            "preferred_language": {
              "type": "string",
              "enum": ["en", "hi", "kn"]
            },
            "qual_score": { "type": "number" },
            "intent": {
              "type": "string",
              "enum": ["just-browsing", "actively-looking", "urgent"]
            },
            "notes": { "type": "string" }
          }
        }
      }
    }
  },
  {
    "name": "search_inventory",
    "description": "Search the Bangalore rental inventory using caller requirements and return scored matches with honest tradeoffs.",
    "method": "POST",
    "url": "{{APP_URL}}/api/agent/search",
    "headers": {
      "Content-Type": "application/json"
    },
    "body_schema": {
      "type": "object",
      "required": ["filters"],
      "properties": {
        "call_id": { "type": "string" },
        "filters": {
          "type": "object",
          "properties": {
            "areas": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["HSR Layout", "Whitefield", "Indiranagar", "Koramangala", "BTM Layout", "JP Nagar", "Marathahalli", "Electronic City"]
              }
            },
            "bhk": {
              "type": "array",
              "items": { "type": "number" }
            },
            "budget_min_inr": { "type": "number" },
            "budget_max_inr": { "type": "number" },
            "furnishing": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["unfurnished", "semi", "fully"]
              }
            },
            "parking_needed": {
              "type": "string",
              "enum": ["bike", "car", "either", "none"]
            },
            "pet_friendly": { "type": "boolean" },
            "veg_only": { "type": "boolean" },
            "occupants": {
              "type": "string",
              "enum": ["family", "bachelor", "couple", "flatmates"]
            },
            "move_in_by": { "type": "string", "description": "YYYY-MM-DD" },
            "min_carpet_sqft": { "type": "number" },
            "amenities": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["gym", "pool", "powerBackup", "security", "clubhouse", "playArea", "joggingTrack", "indoorGames"]
              }
            },
            "limit": { "type": "number", "default": 5 }
          }
        }
      }
    }
  },
  {
    "name": "compare_listings",
    "description": "Compare 2-5 rental listings across cost, deposit, area, furnishing, parking, age, amenities, commute, lift, and availability.",
    "method": "POST",
    "url": "{{APP_URL}}/api/agent/compare",
    "headers": {
      "Content-Type": "application/json"
    },
    "body_schema": {
      "type": "object",
      "required": ["listing_ids"],
      "properties": {
        "call_id": { "type": "string" },
        "listing_ids": {
          "type": "array",
          "minItems": 2,
          "maxItems": 5,
          "items": { "type": "string" }
        }
      }
    }
  },
  {
    "name": "book_visit",
    "description": "Book a visit for a specific listing and slot once the caller confirms.",
    "method": "POST",
    "url": "{{APP_URL}}/api/agent/book-visit",
    "headers": {
      "Content-Type": "application/json"
    },
    "body_schema": {
      "type": "object",
      "required": ["listing_id", "slot_iso"],
      "properties": {
        "call_id": { "type": "string" },
        "lead_id": { "type": "string" },
        "listing_id": { "type": "string" },
        "slot_iso": { "type": "string", "description": "ISO datetime with timezone." },
        "channel": {
          "type": "string",
          "enum": ["in-person", "video"],
          "default": "in-person"
        },
        "notes": { "type": "string" }
      }
    }
  },
  {
    "name": "send_summary",
    "description": "Send or log a written comparison summary for the renter after shortlisting or booking.",
    "method": "POST",
    "url": "{{APP_URL}}/api/agent/send-summary",
    "headers": {
      "Content-Type": "application/json"
    },
    "body_schema": {
      "type": "object",
      "required": ["lead_id", "listing_ids"],
      "properties": {
        "call_id": { "type": "string" },
        "lead_id": { "type": "string" },
        "listing_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "type": "string" }
        },
        "channel": {
          "type": "string",
          "enum": ["sms", "whatsapp", "email"],
          "default": "sms"
        }
      }
    }
  }
]
